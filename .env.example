# ==========================================
# CORE CREDENTIALS (Required)
# ==========================================

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here_example_1234567890

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017
MONGO_DB=pando_bot

# Bot Owner Discord ID (for privileged commands and dashboard OAuth)
OWNER_ID=123456789012345678
DISCORD_OWNER_ID=123456789012345678

# ==========================================
# SUPABASE / DASHBOARD BRIDGE (Optional)
# ==========================================

# Supabase credentials for dashboard sync
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Dashboard bridge sync interval (milliseconds)
DASHBOARD_BRIDGE_INTERVAL_MS=60000
SUPABASE_DASHBOARD_SYNC_INTERVAL_MS=60000
DASHBOARD_HTTP_TIMEOUT_MS=10000

# ==========================================
# MONETIZATION / PRO PLAN (Optional)
# ==========================================

# URL shown in "Pro Required" embeds and /premium command
# Should point to your pricing page (Lemon Squeezy checkout is initiated from there)
PRO_UPGRADE_URL=https://ton618.app/pricing

# Premium Backend Integration (Lemon Squeezy via Supabase)
# REQUIRED IN PRODUCTION: startup exits if BOT_API_KEY is missing while NODE_ENV=production
# Bot API Key for authenticating with billing backend
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Must match BOT_API_KEY in Supabase Edge Functions
BOT_API_KEY=your_secure_random_key_min_32_chars

# ==========================================
# SERVER / HOSTING (Optional)
# ==========================================

# Local development port for the health server
# In production on Square Cloud, prefer PORT=80 and leave SERVER_PORT unused.
SERVER_PORT=8080

# Uncomment only when you want to emulate production port binding locally.
# PORT=80

# Shutdown timeout (milliseconds)
SHUTDOWN_FORCE_TIMEOUT_MS=15000

# Ops console assistive layer and customer memory retention
CUSTOMER_MEMORY_RETENTION_DAYS=90
OPS_ASSISTANT_PROVIDER=deterministic
OPS_ASSISTANT_MODE=assistive
BOT_HEALTHCHECK_URL=http://127.0.0.1:8080/health

# ==========================================
# DISCORD INTENTS (Optional)
# ==========================================

# Enable/disable privileged intents (true/false, 1/0, yes/no, on/off)
MESSAGE_CONTENT_ENABLED=true
GUILD_PRESENCES_ENABLED=true

# ==========================================
# COMMAND MANAGEMENT (Optional)
# ==========================================

# Disable specific commands globally (comma-separated file paths)
# V1 bot-first: comandos genéricos deshabilitados por defecto para enfoque operativo
# Para habilitar alguno, muévelo a COMMANDS_ENABLED_FILES
COMMANDS_DISABLED_FILES=public/utility/ping.js,public/utility/embed.js,public/utility/perfil.js,public/utility/poll.js,public/utility/suggest.js,admin/config/setup/bienvenida.js,admin/config/setup/despedida.js,admin/config/setup/confesiones.js,admin/config/setup/sugerencias.js

# Re-enable specific commands (comma-separated file paths)
COMMANDS_ENABLED_FILES=

# ==========================================
# MONGODB INDEXES (Optional)
# ==========================================

# Auto-create MongoDB indexes on boot (true/false)
MONGO_AUTO_INDEXES=false

# ==========================================
# ERROR LOGGING (Optional)
# ==========================================

# Enable file-based error logging (true/false)
ERROR_LOG_TO_FILE=true

# Directory for error logs (absolute or relative path)
ERROR_LOG_DIR=./data/logs

# ==========================================
# OBSERVABILITY / METRICS (Optional)
# ==========================================

# Enable JSON structured logs for info level (true/false)
ENABLE_JSON_LOGS=false

# Metrics reporting interval (milliseconds)
METRICS_REPORT_INTERVAL_MS=300000

# Error spike alert threshold
ERROR_ALERT_THRESHOLD=5
ERROR_ALERT_COOLDOWN_MS=300000

# ==========================================
# HEALTH MONITORING (Optional)
# ==========================================

# Health monitor intervals and thresholds
HEALTH_HEARTBEAT_MS=60000
HEALTH_EVALUATE_MS=300000
HEALTH_ALERT_COOLDOWN_MS=900000
HEALTH_PING_WARN_MS=300
HEALTH_ERROR_RATE_WARN_PCT=25
HEALTH_MIN_INTERACTIONS=20
HEALTH_DOWNTIME_THRESHOLD_MS=600000

# ==========================================
# RATE LIMITING (Optional)
# ==========================================

# Global rate limit settings (configured per-guild via /setup)
# These are fallback defaults if not set in guild settings

# ==========================================
# TICKET SYSTEM (Optional)
# ==========================================

# Ticket panel image URL (optional)
TICKET_PANEL_IMAGE_URL=

# Auto-assignment settings
AUTO_ASSIGN_ALLOW_FULL_MEMBER_FETCH=false

# ==========================================
# REMINDERS / QUEUES (Optional)
# ==========================================

# Reminders queue concurrency
REMINDERS_QUEUE_CONCURRENCY=4
REMINDERS_QUEUE_MAX_SIZE=2000
REMINDERS_QUEUE_TIMEOUT_MS=60000

# ==========================================
# ALERTS / INTEGRATIONS (Optional)
# ==========================================

# Alert checker interval (minutes)
ALERT_CHECK_INTERVAL_MINUTES=3

# Twitch API credentials (for Twitch alerts)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# YouTube API key (for YouTube alerts)
YOUTUBE_API_KEY=

# ==========================================
# BOT STATS SYNC (Optional)
# ==========================================

# Bot stats HTTP timeout
BOT_STATS_HTTP_TIMEOUT_MS=10000
BOT_STATS_UPTIME_PERCENTAGE=99.9

# ==========================================
# DEPLOYMENT / CI/CD (Optional)
# ==========================================

# Deployment tag (for build fingerprinting)
DEPLOY_TAG=

# Guild IDs for staging/production deploys
STAGING_GUILD_ID=
PRODUCTION_GUILD_ID=
GUILD_ID=
CLEANUP_GUILD_ID=

# Optional guild used for owner-only slash commands like /ping
PRIVATE_COMMANDS_GUILD_ID=

# ==========================================
# USER RATE LIMITING (Optional)
# ==========================================

# Per-user rate limiting (prevents spam)
USER_RATE_LIMIT_MAX_REQUESTS=5
USER_RATE_LIMIT_WINDOW_MS=60000
USER_RATE_LIMIT_BACKOFF=2
USER_RATE_LIMIT_MAX_BACKOFF_MS=300000

# ==========================================
# MONITORING & ALERTING (Production)
# ==========================================

# Sentry for error tracking
SENTRY_DSN=

# Logtail/Better Stack for log aggregation
LOGTAIL_SOURCE_TOKEN=

# Discord webhook for critical alerts
ALERT_DISCORD_WEBHOOK=
