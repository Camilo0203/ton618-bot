# Lemon Squeezy Integration - Bot Configuration
# Copy this to .env and fill in your values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
BOT_API_KEY=your_secure_random_key_here_min_32_chars

# Generate BOT_API_KEY with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# IMPORTANT: This BOT_API_KEY must match the one configured in Supabase Edge Functions
# It's used to authenticate the bot when fetching premium status from Supabase
