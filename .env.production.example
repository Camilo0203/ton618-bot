# TON618 Bot - Production

# ==========================================
# TON618 V1 PRODUCTION ENVIRONMENT
# ==========================================
# Minimal bot-first configuration for production deployment
# Copy this to .env or configure in your hosting platform

# ==========================================
# REQUIRED - Core Credentials
# ==========================================

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=YOUR_REAL_DISCORD_BOT_TOKEN_PASTE_FROM_DEVELOPER_PORTAL_HERE_XXXXXXXXXX

# MongoDB Connection String (MongoDB Atlas recommended)
MONGO_URI=mongodb+srv://user:password@cluster-production.mongodb.net
MONGO_DB=ton618

# Bot Owner Discord ID (for /debug commands)
OWNER_ID=123456789012345678

# ==========================================
# RECOMMENDED - V1 Bot-First Configuration
# ==========================================

# Disable generic utility commands for operational focus
COMMANDS_DISABLED_FILES=public/utility/ping.js,public/utility/embed.js,public/utility/perfil.js,public/utility/poll.js,public/utility/suggest.js,admin/config/setup/bienvenida.js,admin/config/setup/despedida.js,admin/config/setup/confesiones.js,admin/config/setup/sugerencias.js

# ==========================================
# OPTIONAL - Server & Monitoring
# ==========================================

# Port for health check endpoint — Square Cloud requires port 80
PORT=80

# Optional local/dev fallback only. Square Cloud production startup binds to PORT first.
# SERVER_PORT=80

# Deployment tag for version tracking
DEPLOY_TAG=v1.0.0

# Optional guild used for owner-only slash commands like /ping
PRIVATE_COMMANDS_GUILD_ID=

# Production environment flag
NODE_ENV=production

# ==========================================
# OPTIONAL - Discord Intents
# ==========================================

# Enable message content (required for some features)
MESSAGE_CONTENT_ENABLED=true

# Enable presence tracking (for auto-assignment features)
GUILD_PRESENCES_ENABLED=true

# ==========================================
# OPTIONAL - Logging
# ==========================================

# File-based logging is DISABLED on Square Cloud — filesystem is ephemeral (lost on restart).
# Use stdout/stderr only; Square Cloud captures these in its log viewer.
ERROR_LOG_TO_FILE=false
# ERROR_LOG_DIR=./data/logs  # Only safe on persistent storage (not Square Cloud)

# ==========================================
# REQUIRED - Premium/Billing (Lemon Squeezy via Supabase)
# ==========================================

# REQUIRED IN PRODUCTION - startup aborts if this value is missing or shorter than 32 chars
# Shared secret between bot and billing-guild-status Edge Function
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST match BOT_API_KEY configured in Supabase Edge Function secrets
BOT_API_KEY=your_production_bot_api_key_min_32_chars

# Supabase project URL (needed for billing-guild-status queries)
SUPABASE_URL=https://your-production-project.supabase.co

# URL shown in 'Pro Required' embeds and /premium command
PRO_UPGRADE_URL=https://ton618.app/pricing

# ==========================================
# OPTIONAL - Dashboard Integration
# ==========================================
# Only needed if using ton618-web dashboard
# Leave empty for bot-only deployment

SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key
SUPABASE_ANON_KEY=your_production_anon_key

DASHBOARD_BRIDGE_INTERVAL_MS=60000
DASHBOARD_HTTP_TIMEOUT_MS=10000

# ==========================================
# OPTIONAL - Advanced Features
# ==========================================

# Customer memory retention (days)
CUSTOMER_MEMORY_RETENTION_DAYS=90

# Ops assistant configuration
OPS_ASSISTANT_PROVIDER=deterministic
OPS_ASSISTANT_MODE=assistive

# Bot health check URL (for external monitoring)
BOT_HEALTHCHECK_URL=https://bot.ton618.app/health

# ==========================================
# SQUARE CLOUD — Required tuning
# ==========================================

# Auto-create MongoDB indexes on startup (safe to keep enabled; idempotent)
MONGO_AUTO_INDEXES=true

# MongoDB connection pool (keep low on 1024 MB plan)
MONGO_MAX_POOL_SIZE=5

# Health server startup grace period (ms) — prevents Square Cloud from killing
# the process before Discord finishes connecting (~10-30s after MongoDB ready)
HEALTH_STARTUP_GRACE_MS=90000

# Graceful shutdown drain / force-kill timeouts (ms)
SHUTDOWN_DRAIN_TIMEOUT_MS=10000
SHUTDOWN_FORCE_TIMEOUT_MS=30000

# ==========================================
# OPTIONAL — Observability
# ==========================================

# Discord webhook for operational alerts (errors, memory pressure, etc.)
ALERT_DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Sentry DSN for error tracking
# SENTRY_DSN=https://key@org.ingest.sentry.io/project
